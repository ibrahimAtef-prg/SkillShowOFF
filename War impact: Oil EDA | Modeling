Define Dates\n    hist_dates = mdf['date'].iloc[-15:]\n    test_dates = mdf['date'].iloc[-5:]\n    future_dates = pd.date_range(start=test_dates.iloc[-1] + pd.Timedelta(days=1), periods=7)\n\n    # Plot lines\n    axes[i].plot(hist_dates, mdf[col].iloc[-15:], color=OIL['infra'], label='Historical Price', linewidth=2)\n    axes[i].plot(test_dates, mdf[col].iloc[-5:], color=OIL['brent'], marker='o', label='Actual (Test Set)')\n    axes[i].plot(test_dates, test_preds, color=OIL['wti'], linestyle='--', marker='x', label='Model Validation')\n    axes[i].plot(future_dates, forecast, color=OIL['strike'], linestyle=':', marker='s', label='7-Day Forecast')\n\n    # Styling\n    axes[i].set_title(f'War Impact Model: {label} Crude Oil', fontsize=14, fontweight='bold')\n    axes[i].set_ylabel('USD per Barrel')\n    axes[i].grid(True, alpha=0.3)\n    axes[i].legend(loc='upper left')\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-29T04:10:59.949217Z","iopub.execute_input":"2026-03-29T04:10:59.949585Z","iopub.status.idle":"2026-03-29T04:11:01.197855Z","shell.execute_reply.started":"2026-03-29T04:10:59.949547Z","shell.execute_reply":"2026-03-29T04:11:01.19697Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## **1. Evaluation**","metadata":{}},{"cell_type":"code","source":"def evaluate_accuracy(df, col):\n    mdf = df.copy()\n    # Predict daily CHANGE\n    mdf['diff'] = mdf[col].diff()\n    mdf['lag1'] = mdf['diff'].shift(1)\n    mdf['lag2'] = mdf['diff'].shift(2)\n    mdf['lag3'] = mdf['diff'].shift(3)\n    mdf = mdf.dropna()\n\n    feats = ['lag1', 'lag2', 'lag3', 'strait_hormuz_daily_ships', 'iran_production_mbpd']\n    X, y = mdf[feats], mdf['diff']\n    \n    # Split: last 5 days for testing\n    X_train, X_test = X[:-5], X[-5:]\n    y_train, y_test = y[:-5], y[-5:]\n    \n    # Train\n    rf = RandomForestRegressor(n_estimators=200, max_depth=4, random_state=42)\n    rf.fit(X_train, y_train)\n