date'] = pd.to_datetime(events['date'])\n\n# 3. U.S. State-Level Gas Prices (Cross-sectional)\ngas_states = pd.read_csv('/kaggle/input/datasets/alitaqishah/iran-war-oil-shock-2026-brent-and-gas-tracker/iran_war_gas_prices_by_state.csv')\n\nprint(\"Data Successfully Loaded.\")\nprint(f\"Tracking {len(oil_prices)} trading days of price data.\")\nprint(f\"Tracking {len(events)} major geopolitical events.\")\nprint(f\"Tracking localized impact across {len(gas_states)} U.S. states.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-29T04:10:55.491885Z","iopub.execute_input":"2026-03-29T04:10:55.492213Z","iopub.status.idle":"2026-03-29T04:10:55.521491Z","shell.execute_reply.started":"2026-03-29T04:10:55.492165Z","shell.execute_reply":"2026-03-29T04:10:55.520589Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Work on data\n\nBased on what i reviewed the data is already clean, just some columns.drop and Also im not satisfied with long naming of some attributes","metadata":{}},{"cell_type":"code","source":"\noil = oil_prices.rename(columns={\n    'brent_usd_barrel': 'brent',\n    'wti_usd_barrel': 'wti',\n    'dubai_usd_barrel': 'dubai',\n    'us_gas_avg_gallon': 'gas_avg',\n    'us_diesel_avg_gallon': 'diesel_avg',\n    'strait_hormuz_daily_ships': 'hormuz_ships',\n    'iran_production_mbpd': 'iran_prod',\n    'brent_vs_prewar_pct': 'brent_change',\n    'gas_vs_prewar_pct': 'gas_change',\n    'gas_change_from_prewar_dollars': 'gas_diff'\n})\n\n\nevents = events.rename(columns={\n    'event_title': 'event',\n    'brent_price_that_day': 'brent_event'\n})\n\n\ngas = gas_states.rename(columns={\n    'gas_price_mar19_2026': 'price_mar',\n    'gas_price_prewar_feb27': 'price_feb',\n    'gas_price_jan08_2026': 'price_jan',\n    'price_increase_since_war': 'increases',\n    'pct_increase_since_war': 'pct_increases',\n    'price_vs_national_avg': 'national_difference'\n})","metadata":{"trusted":true,"execution":{"iopub.status.busy