e'] = df['price_change'].shift(1)\n    df['lag2_change'] = df['price_change'].shift(2)\n    df['lag3_change'] = df['price_change'].shift(3)\n    \n    return df.dropna()\n\n# We will use ships in the strait and Iran's production as exogenous variables\nfeats = ['lag1_change', 'lag2_change', 'lag3_change', 'strait_hormuz_daily_ships', 'iran_production_mbpd']\n\nfor col, label in [('brent_usd_barrel', 'Brent'), ('wti_usd_barrel', 'WTI')]:\n    mdf = build_diff_features(df.copy(), col)\n    \n    X = mdf[feats]\n    y = mdf['price_change']\n    \n    # Train/Test Split (last 5 days for test)\n    X_train, X_test = X[:-5], X[-5:]\n    y_train, y_test = y[:-5], y[-5:]\n    \n    # 3. Train the Model on PRICE CHANGES\n    rf = RandomForestRegressor(n_estimators=200, max_depth=4, random_state=42)\n    rf.fit(X_train, y_train)\n    \n    # --- FORECASTING THE FUTURE (7 Days) ---\n    change_buf = list(mdf['price_change'].values[-3:]) \n    \n    # Hypothetical future inputs: Strait gradually reopens, Iran production drops\n    future_ships = [min(4 + i, 11) for i in range(1, 8)]\n    future_iran = [1.5, 1.4, 1.3, 1.2, 1.1, 1.0, 1.0] \n    \n    forecast_abs = []\n    \n    # IMPORTANT: Grab the last known actual absolute price to act as our baseline\n    current_future_price = mdf[col].iloc[-1]\n    \n    for i, ships in enumerate(future_ships):\n        X_fc = [[change_buf[-1], change_buf[-2], change_buf[-3], ships, future_iran[i]]]\n        \n        # Predict the CHANGE for tomorrow\n        pred_change = rf.predict(X_fc)[0]\n        \n        # Add the predicted change to the absolute price\n        current_future_price += pred_change\n        forecast_abs.append(round(current_future_price, 2))\n        \n        # Update our buffer with the new predicted change\n        change_buf.append(pred_change)\n        \n    print(f\"\\n{label} 7-Day Forecast (Absolute Prices):\")\n    print(forecast_abs)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-29T0